<UserControl x:Class="GitBranchStats.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:GitBranchStats.UI.Localization"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">

    <StackPanel Margin="12" Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}">
        <TextBlock Text="{loc:Translate Settings_Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Text="{loc:Translate Settings_Hint}" TextWrapping="Wrap"
                   Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}" Margin="0,0,0,14"/>

        <TextBlock Text="{loc:Translate Settings_Language}" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding Languages}"
                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName"
                  Width="240" HorizontalAlignment="Left" Margin="0,0,0,16"/>

        <Button Content="{loc:Translate Settings_CreateTranslation}"
                Click="OnCreateTranslation"
                HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,8"/>
        <Button Content="{loc:Translate Settings_EditTranslation}"
                Click="OnEditTranslation"
                HorizontalAlignment="Left" Padding="10,5"/>
    </StackPanel>
</UserControl>
