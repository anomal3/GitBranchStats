<UserControl x:Class="GitBranchStats.UI.Views.BranchComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:GitBranchStats.UI.Localization"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="450">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel>
        <!-- Compare Controls -->
        <TextBlock Text="{loc:Translate Cmp_CompareBranches}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal">
            <ComboBox ItemsSource="{Binding Branches}"
                      SelectedItem="{Binding BranchA}"
                      DisplayMemberPath="DisplayName"
                      Width="140" Height="26" FontSize="12"/>
            <TextBlock Text="↔" FontSize="16" VerticalAlignment="Center" Margin="6,0,6,0"/>
            <ComboBox ItemsSource="{Binding Branches}"
                      SelectedItem="{Binding BranchB}"
                      DisplayMemberPath="DisplayName"
                      Width="140" Height="26" FontSize="12"/>
            <Button Content="{loc:Translate Cmp_Compare}" Command="{Binding CompareCommand}"
                    Margin="8,0,0,0" Padding="16,4" Height="26" FontSize="12"/>
        </StackPanel>

        <!-- Comparison Result -->
        <Border Visibility="{Binding ShowResult, Converter={StaticResource BoolToVis}}"
                Margin="0,8,0,0" Padding="8" CornerRadius="4"
                Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
                BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBorderKey}}" BorderThickness="1">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} vs {1}">
                            <Binding Path="Result.BranchA"/>
                            <Binding Path="Result.BranchB"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Cmp_CommitsAhead}" Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Result.CommitsAhead}" FontWeight="Bold"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate Cmp_CommitsBehind}" Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Result.CommitsBehind}" FontWeight="Bold"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate Cmp_FilesChanged}" Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Result.FilesChanged}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Translate Cmp_Insertions}" Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Result.Insertions, StringFormat=+{0}}" Foreground="#4EC9B0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Translate Cmp_Deletions}" Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Result.Deletions, StringFormat=-{0}}" Foreground="#E06C75"/>
                </Grid>

                <!-- Unique commits list -->
                <Expander Header="{loc:Translate Cmp_UniqueCommits}" Margin="0,8,0,0" IsExpanded="False">
                    <DataGrid ItemsSource="{Binding Result.UniqueCommits}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              MaxHeight="150" FontSize="11"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Translate Cmp_Col_SHA}" Binding="{Binding ShortSha}" Width="65"/>
                            <DataGridTextColumn Header="{loc:Translate Cmp_Col_Author}" Binding="{Binding AuthorName}" Width="100"/>
                            <DataGridTextColumn Header="{loc:Translate Cmp_Col_Date}" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="85"/>
                            <DataGridTextColumn Header="{loc:Translate Cmp_Col_Message}" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Loading indicator for comparison -->
        <ProgressBar IsIndeterminate="True" Height="16" Margin="0,8,0,0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </StackPanel>
</UserControl>
