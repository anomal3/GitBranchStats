<UserControl x:Class="GitBranchStats.UI.Views.BranchStatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GitBranchStats.UI.Views"
             xmlns:loc="clr-namespace:GitBranchStats.UI.Localization"
             xmlns:converters="clr-namespace:GitBranchStats.UI.Converters"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="450">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GitBranchStats.UI;component/Theme/VsTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StatsToColorConverter x:Key="StatsToColorConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="4">
            <!-- ============================ STATISTICS TAB ============================ -->
            <TabItem Header="{loc:Translate Tab_Stats}">
                <Grid Margin="8" Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ======== HEADER ======== -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{loc:Translate App_Title}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="{loc:Translate Main_Refresh}" Command="{Binding RefreshCommand}"
                                Margin="12,0,0,0" Padding="8,4" VerticalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" Width="60" Height="16" Margin="8,0,0,0"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- ======== BRANCH INFO BAR ======== -->
                    <Border Grid.Row="1" BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBorderKey}}"
                            BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Translate Main_CurrentBranch}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding CurrentBranchName}" FontWeight="Bold"
                                           Foreground="#3794FF"/>
                            </StackPanel>
                            <TextBlock Text="{Binding RepositoryPath}" FontSize="11" Margin="0,2,0,0"
                                       Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- ======== AUTHOR STATISTICS TABLE ======== -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{loc:Translate Main_AuthorStatistics}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding AuthorStats}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserSortColumns="True" CanUserResizeRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  MaxHeight="200" FontSize="12"
                                  RowHeight="26">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Translate Main_Col_Author}" Binding="{Binding AuthorName}" Width="*" FontWeight="Medium"/>
                                <DataGridTextColumn Header="{loc:Translate Main_Col_Commits}" Binding="{Binding CommitCount}" Width="70" TextBlock.TextAlignment="Right"/>
                                <DataGridTextColumn Header="{loc:Translate Main_Col_Files}" Binding="{Binding FilesChanged}" Width="65" TextBlock.TextAlignment="Right"/>
                                <DataGridTextColumn Header="{loc:Translate Main_Col_Additions}" Binding="{Binding Additions, StringFormat=+{0}}" Width="80" TextBlock.TextAlignment="Right">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4EC9B0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{loc:Translate Main_Col_Deletions}" Binding="{Binding Deletions, StringFormat=-{0}}" Width="80" TextBlock.TextAlignment="Right">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#E06C75"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- ======== BRANCH OPERATIONS ======== -->
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Switch Branch -->
                        <Border Grid.Row="0" BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBorderKey}}"
                                BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Main_SwitchBranch}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox ItemsSource="{Binding Branches}"
                                              SelectedItem="{Binding SelectedBranchForSwitch}"
                                              DisplayMemberPath="DisplayName"
                                              Width="220" Height="26"
                                              FontSize="12"/>
                                    <Button Content="{loc:Translate Main_Switch}" Command="{Binding SwitchBranchCommand}"
                                            Margin="8,0,0,0" Padding="16,4" Height="26" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Compare Branches (embedded comparison view) -->
                        <local:BranchComparisonView Grid.Row="1" DataContext="{Binding Comparison}"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================ SETTINGS TAB ============================ -->
            <TabItem Header="{loc:Translate Tab_Settings}">
                <local:SettingsView/>
            </TabItem>
        </TabControl>

        <!-- ======== STATUS BAR ======== -->
        <Border Grid.Row="1" Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}" Padding="4,2"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBorderKey}}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</UserControl>
