<vsui:DialogWindow x:Class="GitBranchStats.UI.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitBranchStats.UI.Localization"
        xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static vs:VsBrushes.WindowKey}}">

    <vsui:DialogWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GitBranchStats.UI;component/Theme/VsTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </vsui:DialogWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="⚠" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Top"
                       Foreground="#E0A030"/>
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" Width="380" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="1" Content="{loc:Translate Dialog_Ok}" Click="OnOk"
                HorizontalAlignment="Right" MinWidth="90" Padding="10,5" Margin="0,16,0,0"
                IsDefault="True" IsCancel="True"/>
    </Grid>
</vsui:DialogWindow>
